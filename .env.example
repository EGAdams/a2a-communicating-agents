# Copy this file to .env and fill in your values
# cp .env.example .env

# === Required for agents ===
OPENAI_API_KEY=

# === Optional LLM providers ===
ANTHROPIC_API_KEY=
GROQ_API_KEY=
GEMINI_API_KEY=
EXA_API_KEY=

# === Server ports ===
ADMIN_PORT=3030
ADMIN_HOST=127.0.0.1

# === Letta (optional, for Letta transport) ===
LETTA_SERVER_URL=http://localhost:8283
LETTA_PG_URI=postgresql+pg8000://letta:letta@localhost:5432/letta
VOICE_PRIMARY_AGENT_ID=
VOICE_PRIMARY_AGENT_NAME=

# === LiveKit (optional, for voice) ===
LIVEKIT_URL=ws://localhost:7880

# === Feature flags ===
USE_HYBRID_STREAMING=false
USE_GROQ_LLM=false
GROQ_MODEL=llama-3.3-70b-versatile
